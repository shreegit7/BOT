DISCORD_TOKEN=your_discord_bot_token_here
QUIZAPI_KEY=your_quizapi_key_here
DEFAULT_PREFIX=!
TZ=UTC

# Optional runtime settings
DATABASE_PATH=data/bot.db
LOG_LEVEL=INFO
SYNC_COMMANDS_ON_STARTUP=true

# Optional health endpoint (useful on Render)
# If PORT is set by platform, bot auto-enables healthcheck by default.
HEALTHCHECK_ENABLED=true
HEALTH_PORT=8080
